---
import Base from '../layouts/Base.astro';
---
<Base
  title="PeptideLab — Research-Grade Peptide Guides & Science"
  description="The most trusted peptide research resource. Expert-written guides on BPC-157, TB-500, Semaglutide, and more — backed by peer-reviewed science."
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">

    <!-- Layered CSS gradient background -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse at 15% 60%, oklch(0.62 0.16 192 / 0.14), transparent 52%),
        radial-gradient(ellipse at 85% 20%, oklch(0.74 0.16 75 / 0.07), transparent 48%),
        radial-gradient(ellipse at 60% 90%, oklch(0.62 0.16 192 / 0.08), transparent 44%),
        linear-gradient(to bottom, oklch(0.11 0.008 250), oklch(0.13 0.009 250));
    "></div>

    <!-- Dot grid texture overlay -->
    <div class="absolute inset-0 bg-dot-grid opacity-60"></div>

    <!-- Thin top accent line -->
    <div class="absolute top-0 left-0 right-0 h-[2px]" style="background: linear-gradient(to right, transparent 0%, oklch(0.62 0.16 192 / 0.8) 30%, oklch(0.74 0.16 75 / 0.9) 60%, transparent 100%);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-4xl">

        <!-- Eyebrow label -->
        <div class="animate-slide-up flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold tracking-widest uppercase border border-brand-500/30 bg-brand-500/10 text-brand-400">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse-glow"></span>
            Research-Grade Resource
          </span>
        </div>

        <!-- H1 -->
        <h1 class="animate-slide-up delay-100 text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight font-display leading-[1.08] text-surface-950">
          Understand peptides<br/>
          <span style="color: oklch(0.62 0.16 192);">before</span> you<br class="hidden md:block"/> ever use one.
        </h1>

        <!-- Subheadline -->
        <p class="animate-slide-up delay-200 mt-7 text-xl md:text-2xl leading-relaxed font-body font-light text-surface-800 max-w-2xl">
          Clear, peer-reviewed guides on BPC-157, TB-500, Semaglutide, and 30+ peptides — written for curious people who want real science, not forum rumors.
        </p>

        <!-- CTAs -->
        <div class="animate-slide-up delay-300 mt-10 flex flex-wrap items-center gap-4">
          <a href="#guides"
             class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-semibold font-display text-base transition-colors duration-150"
             style="background: oklch(0.62 0.16 192); color: oklch(0.11 0.008 250);"
             onmouseover="this.style.background='oklch(0.52 0.15 192)'"
             onmouseout="this.style.background='oklch(0.62 0.16 192)'">
            Explore the research library
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="#newsletter"
             class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg font-semibold font-display text-base border border-surface-200/30 text-surface-900 hover:border-brand-500/50 hover:text-brand-400 transition-colors duration-150">
            Get weekly research digests
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="animate-slide-up delay-400 mt-5 text-sm text-surface-800/50 font-display">
          Free to read. No prescription required. No hype.
        </p>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-24" style="background: linear-gradient(to bottom, transparent, oklch(0.11 0.008 250));"></div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       SOCIAL PROOF BAR
  ═══════════════════════════════════════════════════════════ -->
  <section class="bg-surface-100 border-y border-surface-200/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <p class="text-center text-xs font-semibold tracking-widest uppercase text-surface-800/40 font-display mb-10">
        Trusted by researchers, biohackers & health-focused readers
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display" style="color: oklch(0.62 0.16 192);">34+</p>
          <p class="mt-1 text-sm text-surface-800/60 font-display">Peptide profiles covered</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display" style="color: oklch(0.62 0.16 192);">180+</p>
          <p class="mt-1 text-sm text-surface-800/60 font-display">Peer-reviewed studies cited</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display" style="color: oklch(0.62 0.16 192);">12k+</p>
          <p class="mt-1 text-sm text-surface-800/60 font-display">Monthly readers</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display" style="color: oklch(0.62 0.16 192);">100%</p>
          <p class="mt-1 text-sm text-surface-800/60 font-display">Free to access</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       FEATURES GRID — What You'll Find Here
  ═══════════════════════════════════════════════════════════ -->
  <section id="guides" class="py-24 md:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="max-w-2xl mb-16">
        <p class="text-xs font-semibold tracking-widest uppercase font-display mb-4" style="color: oklch(0.62 0.16 192);">
          What's inside
        </p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight font-display text-surface-950 leading-tight">
          Every guide you need — none of the speculation.
        </h2>
        <p class="mt-5 text-lg text-surface-800/60 leading-relaxed font-body">
          We translate dense research papers into clear, accurate summaries with protocols, mechanisms, and legal context.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Card 1 -->
        <div class="group rounded-2xl border border-surface-200/30 bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3">Mechanism deep-dives</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Understand exactly how each peptide works at the cellular level — receptor binding, half-lives, downstream effects — not just "what it does."
          </p>
        </div>

        <!-- Card 2 -->
        <div class="group rounded-2xl border border-surface-200/30 bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3">Protocol reference sheets</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Dosing windows, administration routes, and cycling patterns drawn directly from human trial data — not bro-science forum posts.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="group rounded-2xl border border-surface-200/30 bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3">Legal & regulatory context</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Clear breakdowns of research-use status, prescription landscapes, and grey-area realities — jurisdiction by jurisdiction.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="group rounded-2xl border border-surface-200/30 bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3">Side effect & safety profiles</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Honest reporting on observed adverse events, contraindications, and drug interactions across available clinical data — including what's still unknown.
          </p>
        </div>

        <!-- Card 5 -->
        <div class="group rounded-2xl border border-surface-200/30 bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 1 1.242 7.244" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3">Sourced from primary literature</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Every claim links to its PubMed source. No anonymous anecdotes. No "experts say." Read the study yourself in one click.
          </p>
        </div>

        <!-- Card 6 -->
        <div class="group rounded-2xl border border-surface-200/30 bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3">Continuously updated</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            New trials publish weekly. We track them and update our guides when the evidence shifts — so you're never reading yesterday's consensus.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       HOW IT WORKS — 3 Steps
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-xs font-semibold tracking-widest uppercase font-display mb-4" style="color: oklch(0.62 0.16 192);">
          How to use this site
        </p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display text-surface-950">
          From curious to informed in three steps
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 relative">

        <!-- Connector line (desktop only) -->
        <div class="hidden md:block absolute top-10 left-1/3 right-1/3 h-[1px]" style="background: linear-gradient(to right, oklch(0.62 0.16 192 / 0.3), oklch(0.62 0.16 192 / 0.3));"></div>

        <!-- Step 1 -->
        <div class="flex flex-col items-start md:items-center md:text-center">
          <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold font-display text-lg mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.15); color: oklch(0.62 0.16 192); border: 1px solid oklch(0.62 0.16 192 / 0.3);">
            01
          </div>
          <h3 class="text-xl font-bold font-display text-surface-950 mb-3">Pick your peptide</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Browse our A–Z index or search by goal — healing, body composition, cognition, longevity. Find the peptide relevant to you.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-start md:items-center md:text-center">
          <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold font-display text-lg mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.15); color: oklch(0.62 0.16 192); border: 1px solid oklch(0.62 0.16 192 / 0.3);">
            02
          </div>
          <h3 class="text-xl font-bold font-display text-surface-950 mb-3">Read the full profile</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Each guide covers mechanism, human trial results, protocols, safety signals, and legal status — everything in one place, no paywalls.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-start md:items-center md:text-center">
          <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold font-display text-lg mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.15); color: oklch(0.62 0.16 192); border: 1px solid oklch(0.62 0.16 192 / 0.3);">
            03
          </div>
          <h3 class="text-xl font-bold font-display text-surface-950 mb-3">Talk to your doctor</h3>
          <p class="text-base text-surface-800/60 leading-relaxed font-body">
            Bring real data to your next consultation. Our guides are designed to make you a better-informed patient, not replace medical advice.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       FEATURED PEPTIDES — mini library preview
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase font-display mb-4" style="color: oklch(0.62 0.16 192);">
            Popular guides
          </p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display text-surface-950">
            Start with the most researched peptides
          </h2>
        </div>
        <a href="/blog" class="shrink-0 inline-flex items-center gap-2 text-sm font-semibold font-display text-brand-400 hover:text-brand-200 transition-colors">
          View full library
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

        <!-- BPC-157 -->
        <a href="/blog" class="group block rounded-2xl border border-surface-200/30 bg-surface-100 p-6 hover:border-brand-500/40 transition-colors duration-200">
          <div class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-display mb-4 tracking-wide" style="background: oklch(0.62 0.16 192 / 0.15); color: oklch(0.62 0.16 192);">
            Healing &amp; Recovery
          </div>
          <h3 class="text-xl font-bold font-display text-surface-950 mb-2 group-hover:text-brand-400 transition-colors">BPC-157</h3>
          <p class="text-sm text-surface-800/55 leading-relaxed font-body">
            Body Protective Compound with strong evidence for tendon, gut, and nerve repair in animal models.
          </p>
          <p class="mt-4 text-xs font-display text-surface-800/40">14 studies reviewed</p>
        </a>

        <!-- TB-500 -->
        <a href="/blog" class="group block rounded-2xl border border-surface-200/30 bg-surface-100 p-6 hover:border-brand-500/40 transition-colors duration-200">
          <div class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-display mb-4 tracking-wide" style="background: oklch(0.62 0.16 192 / 0.15); color: oklch(0.62 0.16 192);">
            Tissue Repair
          </div>
          <h3 class="text-xl font-bold font-display text-surface-950 mb-2 group-hover:text-brand-400 transition-colors">TB-500</h3>
          <p class="text-sm text-surface-800/55 leading-relaxed font-body">
            Synthetic Thymosin Beta-4 fragment with proven angiogenic and anti-inflammatory properties.
          </p>
          <p class="mt-4 text-xs font-display text-surface-800/40">11 studies reviewed</p>
        </a>

        <!-- Semaglutide -->
        <a href="/blog" class="group block rounded-2xl border border-surface-200/30 bg-surface-100 p-6 hover:border-brand-500/40 transition-colors duration-200">
          <div class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-display mb-4 tracking-wide" style="background: oklch(0.74 0.16 75 / 0.15); color: oklch(0.74 0.16 75);">
            Metabolic Health
          </div>
          <h3 class="text-xl font-bold font-display text-surface-950 mb-2 group-hover:text-brand-400 transition-colors">Semaglutide</h3>
          <p class="text-sm text-surface-800/55 leading-relaxed font-body">
            GLP-1 receptor agonist approved for T2D and obesity — the most-discussed peptide of the decade.
          </p>
          <p class="mt-4 text-xs font-display text-surface-800/40">22 studies reviewed</p>
        </a>

        <!-- CJC-1295 -->
        <a href="/blog" class="group block rounded-2xl border border-surface-200/30 bg-surface-100 p-6 hover:border-brand-500/40 transition-colors duration-200">
          <div class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-display mb-4 tracking-wide" style="background: oklch(0.62 0.16 192 / 0.15); color: oklch(0.62 0.16 192);">
            Longevity
          </div>
          <h3 class="text-xl font-bold font-display text-surface-950 mb-2 group-hover:text-brand-400 transition-colors">CJC-1295</h3>
          <p class="text-sm text-surface-800/55 leading-relaxed font-body">
            GHRH analogue that sustainably elevates growth hormone and IGF-1 — popular for body composition and sleep.
          </p>
          <p class="mt-4 text-xs font-display text-surface-800/40">9 studies reviewed</p>
        </a>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       NEWSLETTER / EMAIL CAPTURE
  ═══════════════════════════════════════════════════════════ -->
  <section id="newsletter" class="py-24 md:py-32 bg-surface-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-semibold tracking-widest uppercase font-display mb-4" style="color: oklch(0.62 0.16 192);">
          Weekly digest
        </p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display text-surface-950 mb-5">
          New peptide trials, distilled every week.
        </h2>
        <p class="text-lg text-surface-800/60 leading-relaxed font-body mb-10">
          We scan PubMed so you don't have to. Get a plain-English summary of the most important new peptide research, every Tuesday — free.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
          <input
            type="email"
            name="email"
            required
            placeholder="your@email.com"
            class="flex-1 px-4 py-3 rounded-lg border border-surface-200/40 bg-surface-50 text-surface-950 placeholder-surface-800/40 font-display text-sm focus:outline-none focus:border-brand-500/60 transition-colors"
          />
          <button
            type="submit"
