          <p class="text-base font-semibold font-display text-surface-950 mb-6">
            Join the digest — it's free
          </p>
          <form id="newsletter-form" class="space-y-4">
            <input type="hidden" id="newsletter-token" value={subscribeToken} />
            <div>
              <label for="email-input" class="block text-xs font-semibold font-display mb-2" style="color: oklch(0.60 0.008 250);">
                Your email address
              </label>
              <input
                id="email-input"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="researcher@email.com"
                class="w-full px-4 py-3 rounded-lg border font-display text-sm text-surface-950 focus:outline-none transition-colors duration-150"
                style="background: oklch(0.155 0.009 250); border-color: oklch(0.27 0.010 250);"
                onfocus="this.style.borderColor='oklch(0.62 0.16 192 / 0.7)'"
                onblur="this.style.borderColor='oklch(0.27 0.010 250)'"
              />
            </div>
            <button
              type="submit"
              id="newsletter-btn"
              class="w-full py-3.5 rounded-lg font-bold font-display text-sm transition-colors duration-150"
              style="background: oklch(0.62 0.16 192); color: oklch(0.10 0.008 250);"
              onmouseover="this.style.background='oklch(0.54 0.15 192)'"
              onmouseout="this.style.background='oklch(0.62 0.16 192)'">
              Send me the weekly digest
            </button>
          </form>
          <p id="newsletter-msg" class="mt-3 text-xs font-display text-center hidden"></p>
          <p class="mt-4 text-xs font-display text-center" style="color: oklch(0.46 0.008 250);">
            No spam. We never sell your data. Cancel anytime.
          </p>
          <script>
            const form = document.getElementById('newsletter-form');
            const msg = document.getElementById('newsletter-msg');
            const btn = document.getElementById('newsletter-btn');
            if (form && msg && btn) {
              form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const email = (document.getElementById('email-input') as HTMLInputElement).value;
                const token = (document.getElementById('newsletter-token') as HTMLInputElement).value;
                btn.textContent = 'Subscribing…';
                (btn as HTMLButtonElement).disabled = true;
                try {
                  const resp = await fetch('/api/v1/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, source: 'homepage-newsletter', token }),
                  });
                  msg.classList.remove('hidden', 'text-red-400', 'text-green-400');
                  if (resp.ok) {
                    msg.textContent = '✓ You\'re in! Check your inbox for a confirmation.';
                    msg.classList.add('text-green-400');
                    form.reset();
                    btn.textContent = 'Subscribed!';
                  } else {
                    msg.textContent = 'Something went wrong — please try again.';
                    msg.classList.add('text-red-400');
                    btn.textContent = 'Send me the weekly digest';
                    (btn as HTMLButtonElement).disabled = false;
                  }
                  msg.classList.remove('hidden');
                } catch {
                  msg.textContent = 'Something went wrong — please try again.';
                  msg.classList.add('text-red-400');
                  msg.classList.remove('hidden');
                  btn.textContent = 'Send me the weekly digest';
                  (btn as HTMLButtonElement).disabled = false;
                }
              });
