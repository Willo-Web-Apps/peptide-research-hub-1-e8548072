---
import Base from '../layouts/Base.astro';
const subscribeToken = import.meta.env.PUBLIC_SUBSCRIBE_TOKEN || '';
---
<Base
  title="HelixVault — Peptide Research Guide | Evidence-Based Peptide Information"
  description="Your evidence-based peptide research guide. In-depth profiles on BPC-157, TB-500, Semaglutide, CJC-1295, GHK-Cu, PT-141, and more — mechanisms, trial data, and safety signals from primary literature, not forum hearsay."
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[88vh] flex items-center overflow-hidden">

    <!-- Layered CSS gradient background -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse at 12% 65%, oklch(0.62 0.16 192 / 0.16), transparent 50%),
        radial-gradient(ellipse at 82% 18%, oklch(0.74 0.16 75 / 0.08), transparent 46%),
        radial-gradient(ellipse at 55% 92%, oklch(0.62 0.16 192 / 0.09), transparent 42%),
        linear-gradient(160deg, oklch(0.115 0.009 252), oklch(0.105 0.007 248));
    "></div>

    <!-- Dot-grid texture -->
    <div class="absolute inset-0 bg-dot-grid opacity-50"></div>

    <!-- Top accent gradient line -->
    <div class="absolute top-0 left-0 right-0 h-[2px]" style="
      background: linear-gradient(to right,
        transparent 0%,
        oklch(0.62 0.16 192 / 0.9) 25%,
        oklch(0.74 0.16 75 / 0.85) 55%,
        transparent 100%
      );
    "></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-36">
      <div class="max-w-4xl">

        <!-- Eyebrow -->
        <div class="animate-slide-up flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase border border-brand-500/30 bg-brand-500/10 text-brand-400 font-display">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse-glow"></span>
            Research-Grade Resource
          </span>
        </div>

        <!-- H1 — strong mobile-first layout -->
        <h1 class="animate-slide-up delay-100 font-display font-extrabold tracking-tight leading-[1.04] text-surface-950"
            style="font-size: clamp(2.6rem, 6.5vw, 5rem);">
          Understand peptides<br/>
          <em class="not-italic" style="color: oklch(0.62 0.16 192);">before</em> you ever use one.
        </h1>

        <!-- Subheadline -->
        <p class="animate-slide-up delay-200 mt-7 text-lg md:text-xl leading-relaxed font-body font-light max-w-xl"
           style="color: oklch(0.76 0.008 250);">
          Mechanisms, trial data, safety signals, and legal context — for every major research peptide, drawn from primary literature. No forum hearsay. No supplements sold.
        </p>

        <!-- CTAs -->
        <div class="animate-slide-up delay-300 mt-10 flex flex-wrap items-center gap-4">
          <a href="/blog"
             class="cta-primary inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg font-bold font-display text-base transition-colors duration-150"
             style="background: oklch(0.62 0.16 192); color: oklch(0.10 0.008 250);">
            Open the research library
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" class="w-4 h-4 shrink-0" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="#newsletter"
             class="inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg font-semibold font-display text-base border transition-all duration-150"
             style="border-color: oklch(0.28 0.010 250); color: oklch(0.82 0.006 250);"
             onmouseover="this.style.borderColor='oklch(0.62 0.16 192 / 0.55)'; this.style.color='oklch(0.72 0.14 192)'"
             onmouseout="this.style.borderColor='oklch(0.28 0.010 250)'; this.style.color='oklch(0.82 0.006 250)'">
            Get the weekly digest
          </a>
        </div>

        <!-- Micro-proof -->
        <p class="animate-slide-up delay-400 mt-6 text-sm font-display"
           style="color: oklch(0.55 0.008 250);">
          Free to read &nbsp;·&nbsp; No account needed &nbsp;·&nbsp; No supplements sold
        </p>

      </div>
    </div>

    <!-- Bottom fade into next section -->
    <div class="absolute bottom-0 left-0 right-0 h-28" style="
      background: linear-gradient(to bottom, transparent, oklch(0.11 0.008 250));
    "></div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       STATS BAR
  ═══════════════════════════════════════════════════════════ -->
  <section class="border-y border-surface-200/30" style="background: oklch(0.145 0.009 250);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-12">
      <p class="text-center text-xs font-semibold tracking-widest uppercase font-display mb-9"
         style="color: oklch(0.50 0.008 250);">
        Trusted by researchers, biohackers &amp; clinically-curious readers
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-4 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display tabular-nums" style="color: oklch(0.62 0.16 192);">9</p>
          <p class="mt-1.5 text-sm font-display" style="color: oklch(0.60 0.008 250);">In-depth peptide profiles</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display tabular-nums" style="color: oklch(0.62 0.16 192);">250+</p>
          <p class="mt-1.5 text-sm font-display" style="color: oklch(0.60 0.008 250);">Peer-reviewed studies cited</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display tabular-nums" style="color: oklch(0.62 0.16 192);">100%</p>
          <p class="mt-1.5 text-sm font-display" style="color: oklch(0.60 0.008 250);">Free — no paywall, ever</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold font-display tabular-nums" style="color: oklch(0.62 0.16 192);">Weekly</p>
          <p class="mt-1.5 text-sm font-display" style="color: oklch(0.60 0.008 250);">New research digested</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       FEATURES GRID — What You'll Find Here
  ═══════════════════════════════════════════════════════════ -->
  <section id="guides" class="py-24 md:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header -->
      <div class="max-w-2xl mb-16">
        <p class="text-xs font-semibold tracking-widest uppercase font-display mb-4" style="color: oklch(0.62 0.16 192);">
          What's inside every guide
        </p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight font-display text-surface-950 leading-tight">
          The full picture —<br class="hidden sm:block"/> not just the headlines.
        </h2>
        <p class="mt-5 text-lg leading-relaxed font-body" style="color: oklch(0.68 0.009 250);">
          We go from primary literature to plain English — mechanisms, protocols, safety signals, and legal status in a single guide.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

        <!-- Card 1 -->
        <div class="animate-slide-up delay-100 group rounded-2xl border bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200"
             style="border-color: oklch(0.22 0.010 250 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-5 h-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3 leading-snug">Mechanism deep-dives</h3>
          <p class="text-[0.9375rem] leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
            Receptor binding, half-lives, downstream effects — exactly how each peptide works at the cellular level, not just what it supposedly does.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="animate-slide-up delay-200 group rounded-2xl border bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200"
             style="border-color: oklch(0.22 0.010 250 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-5 h-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3 leading-snug">Protocol reference data</h3>
          <p class="text-[0.9375rem] leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
            Dosing windows, administration routes, and cycling patterns — drawn from human trial data, not anonymous forum posts.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="animate-slide-up delay-300 group rounded-2xl border bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200"
             style="border-color: oklch(0.22 0.010 250 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-5 h-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3 leading-snug">Legal &amp; regulatory context</h3>
          <p class="text-[0.9375rem] leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
            Research-use status, prescription landscapes, and grey-area realities — broken down clearly, jurisdiction by jurisdiction.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="animate-slide-up delay-200 group rounded-2xl border bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200"
             style="border-color: oklch(0.22 0.010 250 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-5 h-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3 leading-snug">Honest safety profiles</h3>
          <p class="text-[0.9375rem] leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
            Observed adverse events, contraindications, drug interactions — including what's still unknown. No safety theatre, no downplaying.
          </p>
        </div>

        <!-- Card 5 -->
        <div class="animate-slide-up delay-300 group rounded-2xl border bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200"
             style="border-color: oklch(0.22 0.010 250 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-5 h-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 1 1.242 7.244" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3 leading-snug">Primary literature only</h3>
          <p class="text-[0.9375rem] leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
            Every claim traces back to a named PubMed study. No anonymous anecdotes. No "experts say." One click to the source.
          </p>
        </div>

        <!-- Card 6 -->
        <div class="animate-slide-up delay-400 group rounded-2xl border bg-surface-100 p-8 hover:border-brand-500/40 transition-colors duration-200"
             style="border-color: oklch(0.22 0.010 250 / 0.5);">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-6 shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="oklch(0.62 0.16 192)" class="w-5 h-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </div>
          <h3 class="text-lg font-bold font-display text-surface-950 mb-3 leading-snug">Updated as evidence evolves</h3>
          <p class="text-[0.9375rem] leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
            New trials publish every week. We track them and revise our guides when the evidence shifts — so you're never relying on a stale consensus.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       HOW IT WORKS — 3 Steps
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32" style="background: oklch(0.145 0.009 250);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-xl mx-auto mb-20">
        <p class="text-xs font-semibold tracking-widest uppercase font-display mb-4" style="color: oklch(0.62 0.16 192);">
          How it works
        </p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display text-surface-950 leading-tight">
          Research in hand. Doctor's visit ready.
        </h2>
        <p class="mt-4 text-base font-body leading-relaxed" style="color: oklch(0.62 0.008 250);">
          Three steps from curious to genuinely informed — no account, no paywall, no barriers.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 lg:gap-12 relative">

        <!-- Connector line (desktop only) — sits at vertical center of the number circles -->
        <div class="hidden md:block absolute h-[1px] top-[1.375rem] left-[calc(33.333%+1.5rem)] right-[calc(33.333%+1.5rem)]"
             style="background: linear-gradient(to right, oklch(0.62 0.16 192 / 0.25), oklch(0.62 0.16 192 / 0.25));"></div>

        <!-- Step 1 -->
        <div class="animate-slide-up delay-100 flex flex-col items-start md:items-center md:text-center gap-5">
          <div class="w-11 h-11 rounded-full flex items-center justify-center font-bold font-display text-sm shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.14); color: oklch(0.72 0.14 192); border: 1px solid oklch(0.62 0.16 192 / 0.35);">
            01
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-surface-950 mb-2">Find your peptide</h3>
            <p class="text-base leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
              Browse by name or filter by goal — healing, metabolic health, cognition, longevity. Nine comprehensive profiles, with more publishing regularly.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="animate-slide-up delay-200 flex flex-col items-start md:items-center md:text-center gap-5">
          <div class="w-11 h-11 rounded-full flex items-center justify-center font-bold font-display text-sm shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.14); color: oklch(0.72 0.14 192); border: 1px solid oklch(0.62 0.16 192 / 0.35);">
            02
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-surface-950 mb-2">Read the full profile</h3>
            <p class="text-base leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
              Mechanism, human trial results, protocol data, safety signals, and legal status — all in one place, no paywall, no login required.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="animate-slide-up delay-300 flex flex-col items-start md:items-center md:text-center gap-5">
          <div class="w-11 h-11 rounded-full flex items-center justify-center font-bold font-display text-sm shrink-0"
               style="background: oklch(0.62 0.16 192 / 0.14); color: oklch(0.72 0.14 192); border: 1px solid oklch(0.62 0.16 192 / 0.35);">
            03
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-surface-950 mb-2">Bring facts to your doctor</h3>
            <p class="text-base leading-relaxed font-body" style="color: oklch(0.62 0.008 250);">
              Our guides make you a better-informed patient. Walk into your consultation with specific questions and real citations — not something you read on Reddit.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════
       GOAL MATRIX — peptide-by-goal reference
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32 bg-surface-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-xs font-semibold tracking-widest uppercase font-display mb-4" style="color: oklch(0.62 0.16 192);">
          Quick reference
        </p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-display text-surface-950 leading-tight">
          Which peptide is researched for what?
        </h2>
        <p class="mt-4 text-base font-body leading-relaxed" style="color: oklch(0.62 0.008 250);">
          At a glance — research focus areas for each compound in our library. Click any peptide for the full evidence review.
        </p>
      </div>

      <!-- Matrix table — desktop visible, scrollable on mobile -->
      <div class="overflow-x-auto -mx-4 px-4">
        <div class="min-w-[680px]">

          <!-- Column headers -->
          <div class="grid gap-px mb-px" style="grid-template-columns: 1fr repeat(5, minmax(0,1fr));">
            <div class="px-4 py-3 text-xs font-semibold font-display tracking-widest uppercase" style="color: oklch(0.50 0.008 250);">Peptide</div>
            <div class="px-4 py-3 text-xs font-semibold font-display text-center" style="color: oklch(0.62 0.16 192);">Healing</div>
            <div class="px-4 py-3 text-xs font-semibold font-display text-center" style="color: oklch(0.74 0.16 75);">Metabolic</div>
            <div class="px-4 py-3 text-xs font-semibold font-display text-center" style="color: oklch(0.65 0.14 145);">Longevity</div>
            <div class="px-4 py-3 text-xs font-semibold font-display text-center" style="color: oklch(0.72 0.14 280);">Cognition</div>
            <div class="px-4 py-3 text-xs font-semibold font-display text-center" style="color: oklch(0.68 0.16 30);">Composition</div>
          </div>

          <!-- Matrix rows -->
          {[
            { name: 'BPC-157', href: '/blog/bpc-157-complete-guide', healing: 'strong', metabolic: null, longevity: null, cognition: 'mild', composition: null },
            { name: 'TB-500', href: '/blog/tb-500-thymosin-beta-4', healing: 'strong', metabolic: null, longevity: 'mild', cognition: null, composition: null },
            { name: 'Semaglutide', href: '/blog/semaglutide-research-guide', healing: null, metabolic: 'strong', longevity: 'mild', cognition: null, composition: 'strong' },
            { name: 'CJC-1295', href: '/blog/cjc-1295-research-guide', healing: 'mild', metabolic: null, longevity: 'strong', cognition: null, composition: 'strong' },
            { name: 'Ipamorelin', href: '/blog/ipamorelin-research-guide', healing: null, metabolic: null, longevity: 'strong', cognition: null, composition: 'strong' },
            { name: 'GHK-Cu', href: '/blog/ghk-cu-research-guide', healing: 'strong', metabolic: null, longevity: 'mild', cognition: null, composition: null },
            { name: 'Epithalon', href: '/blog/epithalon-research-guide', healing: null, metabolic: null, longevity: 'strong', cognition: 'mild', composition: null },
            { name: 'Selank', href: '/blog/selank-research-guide', healing: null, metabolic: null, longevity: null, cognition: 'strong', composition: null },
