---
import Base from '../layouts/Base.astro';
import EmailCapture from '../components/EmailCapture.astro';
---

<Base
  title="Research Resources | HelixVault"
  description="Premium peptide research guides, workbooks, and reference PDFs — from evidence tier breakdowns to full biomarker tracking systems."
>

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-white/10 py-20 px-4">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 50% at 50% 0%, oklch(0.62 0.16 192 / 0.1), transparent);"></div>
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold font-display mb-6 border"
           style="background: oklch(0.62 0.16 192 / 0.1); border-color: oklch(0.62 0.16 192 / 0.3); color: oklch(0.72 0.16 192);">
        📚 HelixVault Research Library
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold font-display text-white leading-tight mb-5">
        Premium Peptide Research Resources
      </h1>
      <p class="text-lg text-white/50 leading-relaxed max-w-2xl mx-auto">
        Evidence-based guides, planning workbooks, and reference PDFs built for serious researchers. Free downloads and premium deep-dives — all grounded in peer-reviewed science.
      </p>
    </div>
  </section>

  <!-- Free Resources -->
  <section class="py-16 px-4 border-b border-white/10">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm" style="background: oklch(0.62 0.16 192 / 0.15);">🆓</div>
        <div>
          <h2 class="text-2xl font-bold font-display text-white">Free Downloads</h2>
          <p class="text-sm text-white/40 mt-0.5">No purchase required — download instantly</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">

        <!-- Starter Kit -->
        <div class="rounded-2xl border border-white/10 p-8 flex flex-col gap-5 hover:border-brand-400/40 transition-all duration-200 group" style="background: oklch(0.16 0.02 250);">
          <div class="flex items-start justify-between gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0" style="background: oklch(0.62 0.16 192 / 0.15);">🧬</div>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full" style="background: oklch(0.62 0.16 192 / 0.2); color: oklch(0.72 0.16 192);">FREE</span>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-white mb-2 group-hover:text-brand-400 transition-colors">Peptide Research Starter Kit</h3>
            <p class="text-white/50 text-sm leading-relaxed">Everything you need to start researching peptides intelligently. Covers the HelixVault evidence tier system, top 12 peptides by goal, the 10-question research checklist, legal framework, and doctor conversation guide.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Evidence Tiers', '12 Peptides', 'Research Checklist', 'Legal Guide'].map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: oklch(0.22 0.03 250); color: oklch(0.75 0.05 250);">{tag}</span>
            ))}
          </div>
          <div class="mt-auto pt-2">
            <a href="https://kufdcnvteecdsgfbxbyn.supabase.co/storage/v1/object/public/business-assets/aa6877ad-ed54-4c6e-9e3e-563709617206/pdfs/helixvault-peptide-research-starter-kit-56bbc171.pdf"
               target="_blank"
               class="flex items-center justify-center gap-2 w-full py-3 rounded-xl font-semibold font-display text-sm transition-all duration-150"
               style="background: oklch(0.62 0.16 192); color: oklch(0.11 0.008 250);"
               onmouseover="this.style.background='oklch(0.52 0.15 192)'"
               onmouseout="this.style.background='oklch(0.62 0.16 192)'">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download Free PDF
            </a>
          </div>
        </div>

        <!-- Red Flags Guide -->
        <div class="rounded-2xl border border-white/10 p-8 flex flex-col gap-5 hover:border-brand-400/40 transition-all duration-200 group" style="background: oklch(0.16 0.02 250);">
          <div class="flex items-start justify-between gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0" style="background: oklch(0.72 0.18 25 / 0.15);">🚩</div>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full" style="background: oklch(0.62 0.16 192 / 0.2); color: oklch(0.72 0.16 192);">FREE</span>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-white mb-2 group-hover:text-brand-400 transition-colors">Peptide Research Red Flags Guide</h3>
            <p class="text-white/50 text-sm leading-relaxed">15 warning signs across bad science, vendor red flags, and marketing manipulation. Includes a printable checklist with a scoring guide. Essential reading before trusting any source.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {['15 Red Flags', 'Vendor Checks', 'Source Evaluation', 'Printable Checklist'].map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: oklch(0.22 0.03 250); color: oklch(0.75 0.05 250);">{tag}</span>
            ))}
          </div>
          <div class="mt-auto pt-2">
            <a href="https://kufdcnvteecdsgfbxbyn.supabase.co/storage/v1/object/public/business-assets/aa6877ad-ed54-4c6e-9e3e-563709617206/pdfs/peptide-research-red-flags-guide-b7dcae40.pdf"
               target="_blank"
               class="flex items-center justify-center gap-2 w-full py-3 rounded-xl font-semibold font-display text-sm transition-all duration-150"
               style="background: oklch(0.62 0.16 192); color: oklch(0.11 0.008 250);"
               onmouseover="this.style.background='oklch(0.52 0.15 192)'"
               onmouseout="this.style.background='oklch(0.62 0.16 192)'">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download Free PDF
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Premium Resources -->
  <section class="py-16 px-4 border-b border-white/10">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm" style="background: oklch(0.82 0.18 85 / 0.15);">⭐</div>
        <div>
          <h2 class="text-2xl font-bold font-display text-white">Premium Guides</h2>
          <p class="text-sm text-white/40 mt-0.5">Deep-dive reference PDFs for serious researchers</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-6">

        <!-- Stack Blueprint -->
        <div class="rounded-2xl border border-white/10 p-8 flex flex-col gap-5 hover:border-brand-400/40 transition-all duration-200 group" style="background: oklch(0.16 0.02 250);">
          <div class="flex items-start justify-between gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0" style="background: oklch(0.55 0.18 145 / 0.15);">💊</div>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full" style="background: oklch(0.82 0.18 85 / 0.2); color: oklch(0.82 0.18 85);">$24</span>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-white mb-2 group-hover:text-brand-400 transition-colors">Peptide Stack Blueprint</h3>
            <p class="text-white/50 text-sm leading-relaxed">5 goal-specific stacking protocols — fat loss, recovery, longevity, cognitive, and sleep. Includes 12-week timelines, synergy breakdowns, and evidence tiers for 18+ peptides.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {['5 Protocols', '18+ Peptides', '12-Week Timelines', 'Synergy Maps'].map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: oklch(0.22 0.03 250); color: oklch(0.75 0.05 250);">{tag}</span>
            ))}
          </div>
          <div class="mt-auto pt-2">
            <a href="https://api.willo.ai/api/checkout/aa6877ad-ed54-4c6e-9e3e-563709617206/price_1TT7WPPiBZvlTKlx1Nux9yre"
               target="_blank"
               class="flex items-center justify-center gap-2 w-full py-3 rounded-xl font-semibold font-display text-sm border transition-all duration-150 hover:bg-white/10"
               style="border-color: oklch(0.62 0.16 192 / 0.5); color: oklch(0.72 0.16 192);">
              Get for $24 →
            </a>
          </div>
        </div>

        <!-- Biomarker Bible — featured -->
        <div class="rounded-2xl border-2 p-8 flex flex-col gap-5 transition-all duration-200 group relative" style="border-color: oklch(0.62 0.16 192 / 0.5); background: oklch(0.18 0.04 210);">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="text-xs font-bold px-3 py-1 rounded-full text-white" style="background: oklch(0.62 0.16 192);">MOST DETAILED</span>
          </div>
          <div class="flex items-start justify-between gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0" style="background: oklch(0.62 0.16 192 / 0.15);">🔬</div>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full" style="background: oklch(0.82 0.18 85 / 0.2); color: oklch(0.82 0.18 85);">$29</span>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-white mb-2 group-hover:text-brand-400 transition-colors">Peptide Biomarker Bible</h3>
            <p class="text-white/50 text-sm leading-relaxed">60+ biomarkers across 8 lab panels — hormonal, metabolic, immune, inflammation, and peptide-specific. Includes optimal ranges, 3-phase testing schedules, and signal interpretation guides.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {['60+ Biomarkers', '8 Lab Panels', 'Optimal Ranges', 'Testing Schedules'].map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: oklch(0.62 0.16 192 / 0.15); color: oklch(0.72 0.16 192);">{tag}</span>
            ))}
          </div>
          <div class="mt-auto pt-2">
            <a href="https://api.willo.ai/api/checkout/aa6877ad-ed54-4c6e-9e3e-563709617206/price_1TT7WQPiBZvlTKlxvxczMqhm"
               target="_blank"
               class="flex items-center justify-center gap-2 w-full py-3 rounded-xl font-semibold font-display text-sm transition-all duration-150 text-white"
               style="background: oklch(0.62 0.16 192);"
               onmouseover="this.style.background='oklch(0.52 0.15 192)'"
               onmouseout="this.style.background='oklch(0.62 0.16 192)'">
              Get for $29 →
            </a>
          </div>
        </div>

        <!-- Cycle Planner -->
        <div class="rounded-2xl border border-white/10 p-8 flex flex-col gap-5 hover:border-brand-400/40 transition-all duration-200 group" style="background: oklch(0.16 0.02 250);">
          <div class="flex items-start justify-between gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0" style="background: oklch(0.62 0.16 260 / 0.15);">📋</div>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full" style="background: oklch(0.82 0.18 85 / 0.2); color: oklch(0.82 0.18 85);">$19</span>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-white mb-2 group-hover:text-brand-400 transition-colors">Peptide Cycle Planner Workbook</h3>
            <p class="text-white/50 text-sm leading-relaxed">A complete 12-week planning workbook with protocol design templates, daily observation logs, biomarker tracking grids, compound response ratings, and end-of-cycle review frameworks.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {['12-Week Planner', 'Observation Logs', 'Biomarker Grids', 'Cycle Review'].map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: oklch(0.22 0.03 250); color: oklch(0.75 0.05 250);">{tag}</span>
            ))}
          </div>
          <div class="mt-auto pt-2">
            <a href="https://api.willo.ai/api/checkout/aa6877ad-ed54-4c6e-9e3e-563709617206/price_1TT7WQPiBZvlTKlxRpK3W2Xy"
               target="_blank"
               class="flex items-center justify-center gap-2 w-full py-3 rounded-xl font-semibold font-display text-sm border transition-all duration-150 hover:bg-white/10"
               style="border-color: oklch(0.62 0.16 192 / 0.5); color: oklch(0.72 0.16 192);">
              Get for $19 →
            </a>
          </div>
        </div>

        <!-- Research Digest -->
        <div class="rounded-2xl border border-white/10 p-8 flex flex-col gap-5 hover:border-brand-400/40 transition-all duration-200 group" style="background: oklch(0.16 0.02 250);">
          <div class="flex items-start justify-between gap-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl shrink-0" style="background: oklch(0.72 0.16 220 / 0.15);">📰</div>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full" style="background: oklch(0.82 0.18 85 / 0.2); color: oklch(0.82 0.18 85);">$14</span>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-white mb-2 group-hover:text-brand-400 transition-colors">Annual Peptide Research Digest 2026</h3>
            <p class="text-white/50 text-sm leading-relaxed">State-of-the-science annual report. 47 peptides tracked, 200+ studies reviewed, 4 major breakthroughs, regulatory updates, evidence rankings, and 2026–2027 research predictions.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {['47 Peptides', '200+ Studies', 'Regulatory Update', '2027 Predictions'].map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: oklch(0.22 0.03 250); color: oklch(0.75 0.05 250);">{tag}</span>
            ))}
          </div>
          <div class="mt-auto pt-2">
            <a href="https://api.willo.ai/api/checkout/aa6877ad-ed54-4c6e-9e3e-563709617206/price_1TT7WPPiBZvlTKlx7JAv0seG"
               target="_blank"
               class="flex items-center justify-center gap-2 w-full py-3 rounded-xl font-semibold font-display text-sm border transition-all duration-150 hover:bg-white/10"
               style="border-color: oklch(0.62 0.16 192 / 0.5); color: oklch(0.72 0.16 192);">
              Get for $14 →
            </a>
          </div>
        </div>

      </div>

      <!-- Bundle CTA -->
      <div class="rounded-2xl p-8 flex flex-col sm:flex-row items-center gap-6 relative overflow-hidden" style="background: linear-gradient(135deg, oklch(0.15 0.02 250), oklch(0.2 0.04 220));">
        <div class="absolute inset-0 pointer-events-none opacity-30" style="background: radial-gradient(ellipse 60% 80% at 80% 50%, oklch(0.62 0.16 192 / 0.3), transparent);"></div>
        <div class="flex-1 relative z-10 text-center sm:text-left">
          <div class="inline-flex items-center gap-2 text-xs font-bold px-3 py-1 rounded-full mb-3" style="background: oklch(0.82 0.18 85 / 0.2); color: oklch(0.82 0.18 85);">
            🎁 BEST VALUE — SAVE $27
          </div>
          <h3 class="text-2xl font-bold font-display text-white mb-2">Complete Peptide Research Kit</h3>
          <p class="text-white/60 text-sm leading-relaxed max-w-xl">All 4 premium guides in one bundle: Stack Blueprint + Cycle Planner + Biomarker Bible + Annual Research Digest. Everything you need to research, plan, and track peptide protocols.</p>
        </div>
        <div class="relative z-10 flex flex-col items-center gap-3 shrink-0">
          <div class="text-center">
            <div class="text-white/40 text-sm line-through">$86 individually</div>
            <div class="text-4xl font-bold text-white font-display">$59</div>
          </div>
          <a href="https://api.willo.ai/api/checkout/aa6877ad-ed54-4c6e-9e3e-563709617206/price_1TT7WUPiBZvlTKlxTCoQBbAm"
             target="_blank"
             class="px-8 py-3 rounded-xl font-bold font-display text-sm transition-all duration-150 whitespace-nowrap"
             style="background: oklch(0.62 0.16 192); color: oklch(0.11 0.008 250);"
             onmouseover="this.style.background='oklch(0.52 0.15 192)'"
             onmouseout="this.style.background='oklch(0.62 0.16 192)'">
            Get the Bundle →
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-16 px-4" id="newsletter">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold font-display text-white mb-2">Stay ahead of the research</h2>
        <p class="text-white/50 text-sm">Get peptide research updates, new guides, and evidence summaries delivered to your inbox.</p>
      </div>
      <EmailCapture source="resources-page" />
    </div>
  </section>

</Base>
