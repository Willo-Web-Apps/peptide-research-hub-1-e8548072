---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate
  ? post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const tags = post.data.tags ?? [];

// Dynamic reading time — approx 220 words per minute
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 220));
const readingTime = `${readingMinutes} min read`;

// Related posts — same primary tag, excluding current
const allPosts = await getCollection('blog');
const primaryTag = tags[0];
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.tags?.includes(primaryTag))
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0))
  .slice(0, 3);

// If fewer than 3 related by tag, fill from recents
const fillPosts = allPosts
  .filter((p) => p.id !== post.id && !relatedPosts.find((r) => r.id === p.id))
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0));

const displayRelated = [...relatedPosts, ...fillPosts].slice(0, 3);

// Tag color map
const tagColors: Record<string, string> = {
  'Healing & Recovery': 'oklch(0.62 0.16 192)',
  'Tissue Repair': 'oklch(0.62 0.16 192)',
  'Metabolic Health': 'oklch(0.74 0.16 75)',
  'Longevity': 'oklch(0.65 0.14 145)',
  'Cognition': 'oklch(0.72 0.14 280)',
  'Body Composition': 'oklch(0.68 0.16 30)',
};
---
<Base
  title={`${post.data.title} — HelixVault`}
  description={post.data.description}
  pageType="article"
  pubDate={post.data.pubDate}
  ogImage={post.data.ogImage}
  tags={post.data.tags}
>

  <!-- Article hero -->
  <section class="relative pt-16 pb-10 md:pt-24 md:pb-14 overflow-hidden">
    <!-- Subtle gradient background -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse at 10% 40%, oklch(0.62 0.16 192 / 0.08), transparent 50%),
        radial-gradient(ellipse at 90% 10%, oklch(0.74 0.16 75 / 0.05), transparent 50%),
        linear-gradient(to bottom, oklch(0.13 0.010 250), oklch(0.11 0.008 250));
    "></div>
    <!-- Top accent line -->
    <div class="absolute top-0 left-0 right-0 h-[2px]" style="background: linear-gradient(to right, transparent 0%, oklch(0.62 0.16 192 / 0.6) 30%, oklch(0.74 0.16 75 / 0.7) 60%, transparent 100%);"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs font-display text-surface-800/40 mb-8">
        <a href="/" class="hover:text-brand-400 transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
          <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
        <a href="/blog" class="hover:text-brand-400 transition-colors">Research Library</a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
          <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
        <span class="text-surface-800/60">{post.data.title}</span>
      </nav>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.slice(0, 4).map((tag: string) => (
            <span class="inline-block px-2.5 py-0.5 rounded text-xs font-semibold font-display tracking-wide"
                  style="background: oklch(0.62 0.16 192 / 0.12); color: oklch(0.62 0.16 192);">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Title -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-surface-950 font-display leading-tight mb-6">
        {post.data.title}
      </h1>

      {post.data.description && (
        <p class="text-lg text-surface-800/60 leading-relaxed font-body mb-8">
          {post.data.description}
        </p>
      )}

      <!-- Meta row -->
      <div class="flex items-center gap-6 pt-6 border-t border-surface-200/20">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background: oklch(0.62 0.16 192 / 0.15); border: 1px solid oklch(0.62 0.16 192 / 0.3);">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="oklch(0.62 0.16 192)" class="w-4 h-4">
              <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-display font-semibold text-surface-950">HelixVault Research Team</p>
            {formattedDate && (
              <time class="text-xs font-display text-surface-800/40">{formattedDate}</time>
            )}
          </div>
        </div>
        <!-- Reading time estimate -->
        <div class="flex items-center gap-1.5 text-xs font-display text-surface-800/40">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          {readingTime}
        </div>
        <!-- Research-only badge -->
        <span class="ml-auto inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold font-display border"
              style="border-color: oklch(0.74 0.16 75 / 0.3); color: oklch(0.74 0.16 75); background: oklch(0.74 0.16 75 / 0.08);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
            <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
          </svg>
          Research purposes only
        </span>
      </div>
    </div>
  </section>

  <!-- Disclaimer banner -->
  <div class="border-y border-surface-200/20" style="background: oklch(0.74 0.16 75 / 0.05);">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex items-start gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="oklch(0.74 0.16 75)" class="w-4 h-4 mt-0.5 shrink-0">
        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
      </svg>
      <p class="text-xs font-display text-surface-800/55 leading-relaxed">
        <strong class="text-surface-800/80">Educational content only.</strong> This guide is for research and informational purposes. It does not constitute medical advice, diagnosis, or treatment. Consult a qualified healthcare provider before making any health decisions.
      </p>
    </div>
  </div>

  <!-- Article body -->
  <article class="py-14 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose-dark">
        <Content />
      </div>

      <!-- Article footer -->
      <div class="mt-16 pt-10 border-t border-surface-200/20">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <a href="/blog"
             class="inline-flex items-center gap-2 text-sm font-semibold font-display text-brand-400 hover:text-brand-300 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Back to Research Library
          </a>
          <!-- Share nudge -->
          <p class="text-xs font-display text-surface-800/40">Found this useful? Share it with someone who'd benefit.</p>
        </div>
      </div>
    </div>
  </article>

  <!-- Related Posts -->
  {displayRelated.length > 0 && (
    <section class="border-t border-surface-200/20 bg-surface-50 py-16 md:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold font-display text-surface-950 mb-8">More from the research library</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {displayRelated.map((related) => {
            const rTag = related.data.tags?.[0] ?? 'Research';
            const rColor = tagColors[rTag] ?? 'oklch(0.62 0.16 192)';
            return (
              <a
                href={`/blog/${related.id}`}
                class="group block rounded-xl border border-surface-200/30 bg-surface-100 p-5 hover:border-brand-500/40 transition-colors duration-150"
              >
                <span
                  class="inline-block px-2 py-0.5 rounded text-xs font-semibold font-display tracking-wide mb-3"
                  style={`background: ${rColor.replace(')', ' / 0.12)')}; color: ${rColor};`}
                >
                  {rTag}
                </span>
                <h3 class="text-sm font-bold font-display text-surface-950 leading-snug mb-2 group-hover:text-brand-400 transition-colors duration-150">
                  {related.data.title}
                </h3>
                {related.data.description && (
                  <p class="text-xs text-surface-800/50 leading-relaxed font-body line-clamp-2">
                    {related.data.description}
                  </p>
                )}
                <span class="inline-flex items-center gap-1 text-xs font-semibold font-display text-brand-400 mt-3 group-hover:gap-2 transition-all duration-150">
                  Read guide
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter CTA at bottom -->
  <section class="border-t border-surface-200/20 bg-surface-100 py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs font-semibold tracking-widest uppercase font-display mb-3" style="color: oklch(0.62 0.16 192);">Stay current</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight font-display text-surface-950 mb-4">
        New research drops weekly.
      </h2>
      <p class="text-base text-surface-800/55 leading-relaxed font-body mb-8 max-w-md mx-auto">
        Get plain-English summaries of the latest peptide trials, every Tuesday. Free, no spam.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto" action="#" method="POST">
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 rounded-lg border border-surface-200/40 bg-surface-50 text-surface-950 placeholder-surface-800/40 font-display text-sm focus:outline-none focus:border-brand-500/60 transition-colors"
        />
        <button
          type="submit"
          class="px-5 py-3 rounded-lg font-semibold font-display text-sm transition-colors duration-150 shrink-0"
          style="background: oklch(0.62 0.16 192); color: oklch(0.11 0.008 250);"
        >
          Subscribe
        </button>
      </form>
      <p class="mt-3 text-xs text-surface-800/35 font-display">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

</Base>
