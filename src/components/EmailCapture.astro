---
interface Props {
  source?: string;
}
const { source = 'website' } = Astro.props;
const subscribeToken = import.meta.env.PUBLIC_SUBSCRIBE_TOKEN || '';
---
<div class="bg-brand-50 rounded-2xl p-8 my-12 text-center">
  <h3 class="text-xl font-bold text-surface-900 mb-2">Stay in the loop</h3>
  <p class="text-surface-800/60 mb-6 text-sm">Get updates, tips, and news delivered to your inbox.</p>
  <form id="email-capture-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
    <input type="hidden" name="source" value={source} />
    <input type="hidden" name="token" value={subscribeToken} />
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      class="flex-1 px-4 py-2.5 rounded-lg border border-surface-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
    />
    <button
      type="submit"
      class="px-5 py-2.5 bg-brand-500 text-white text-sm font-semibold rounded-lg hover:bg-brand-600 transition-colors whitespace-nowrap"
    >
      Subscribe
    </button>
  </form>
  <p id="email-capture-msg" class="mt-3 text-sm hidden"></p>
</div>

<script>
  const form = document.getElementById('email-capture-form') as HTMLFormElement | null;
  const msg = document.getElementById('email-capture-msg');
  if (form && msg) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const email = data.get('email');
      const source = data.get('source');
      const token = data.get('token');
      try {
        const resp = await fetch('/api/v1/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source, token }),
        });
        msg.classList.remove('hidden', 'text-red-600', 'text-green-600');
        if (resp.ok) {
          msg.textContent = 'Thanks for subscribing!';
          msg.classList.add('text-green-600');
          form.reset();
        } else {
          msg.textContent = 'Something went wrong. Please try again.';
          msg.classList.add('text-red-600');
          msg.classList.remove('hidden');
        }
      } catch {
        msg.classList.remove('hidden');
        msg.textContent = 'Something went wrong. Please try again.';
        msg.classList.add('text-red-600');
      }
    });
  }
</script>
