---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = "HelixVault — Research-Grade Peptide Guides & Science",
  description = "The most trusted peptide research resource. Expert-written guides on BPC-157, TB-500, Semaglutide, and more — backed by peer-reviewed science.",
  ogImage = "https://helixvault.onrender.com/og-default.png",
  canonical,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, "https://helixvault.onrender.com").toString();
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:site_name"   content="HelixVault" />
    <meta property="og:locale"      content="en_US" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Robots / indexing -->
    <meta name="robots" content="index, follow" />

    <!-- Theme color (browser chrome on mobile) -->
    <meta name="theme-color" content="#0d1117" />

    <!-- Favicon (inline SVG data URI — no file needed) -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%231a1f2e'/%3E%3Cpath d='M11 5v5.6a3 3 0 0 1-.88 2.12L6 17' stroke='%2322d3c8' stroke-width='2.2' stroke-linecap='round' fill='none'/%3E%3Cpath d='M11 5c-.33.03-.67.07-1 .11m1-.11a32.4 32.4 0 0 1 6 0m0 0v5.6c0 .8.32 1.56.88 2.12L26.4 22' stroke='%2322d3c8' stroke-width='2.2' stroke-linecap='round' fill='none'/%3E%3Cpath d='M17 5c.33.03.67.07 1 .11' stroke='%2322d3c8' stroke-width='2.2' stroke-linecap='round' fill='none'/%3E%3C/svg%3E" />

    <!-- Structured data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "HelixVault",
      "url": "https://helixvault.onrender.com",
      "description": "Research-grade peptide guides and science for curious, health-conscious adults.",
      "potentialAction": {
        "@type": "ReadAction",
        "target": "https://helixvault.onrender.com/blog"
      }
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
